{
  "name": "rate-your-music-modern",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "sync:preview": "node scripts/build-preview-css.mjs && node scripts/build-preview-pages.mjs",
    "check": "npm run sync:preview && npm run format:check && npm run lint && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && stylelint \"rate-your-music-modern.css\" \"preview.css\"",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.59.1",
    "@types/tampermonkey": "^5.0.5",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "prettier": "^3.8.3",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "vite": "^8.0.11"
  }
}
